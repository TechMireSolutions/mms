# Copy to apps/frontend/.env.local for overrides (optional in dev).
# Production build: VITE_APP_DOMAIN is set from MMS_APP_DOMAIN in deploy.yml.

# Apex platform domain — tenants use {subdomain}.<this-domain>
VITE_APP_DOMAIN=your-platform-domain.com

# Optional absolute API origin when not using same-host reverse proxy
# VITE_API_URL=https://your-platform-domain.com
