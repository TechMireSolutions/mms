# Copy to apps/frontend/.env.local for overrides (optional in dev).
# Production build: set VITE_APP_DOMAIN in GitHub Actions (see deploy.yml).

# Apex platform domain — tenant workspaces use {subdomain}.mmsv2.aabtaab.com
VITE_APP_DOMAIN=mmsv2.aabtaab.com

# Optional absolute API origin when not using same-host reverse proxy
# VITE_API_URL=https://mmsv2.aabtaab.com
