{
  "name": "mms-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc && cp src/db/seeds.json.gz dist/db/seeds.json.gz && (cp src/db/seeds.json dist/db/seeds.json || true)",
    "start": "node dist/index.js",
    "worker:start": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --quiet",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@mms/shared": "workspace:*",
    "pg": "^8.13.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "nodemailer": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/pg": "^8.11.10",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
