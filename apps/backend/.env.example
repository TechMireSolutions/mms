# ==============================================================================
# MADRASA MANAGEMENT SYSTEM (MMS) — BACKEND ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to apps/backend/.env for local dev (never commit .env).
# Production: set the same keys as GitHub repository secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE SERVER & CRYPTOGRAPHIC SECURITY
# ------------------------------------------------------------------------------
# High-entropy 256-bit cryptographic hex key for Fastify JWT and session cookies.
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-256-bit-random-hex-key

# Server Environment Mode: development | production | test
NODE_ENV=development

# Network Binding & Listening Ports
# Local Dev: PORT=3000 | Production Hetzner: PORT=5002 (behind Apache Proxy)
PORT=3000
HOST=0.0.0.0

# ------------------------------------------------------------------------------
# 2. DATABASE & POOLING (PostgreSQL + Drizzle ORM)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mms
PG_POOL_MAX=20

# ------------------------------------------------------------------------------
# 3. DOMAINS, CORS & MULTI-TENANCY
# ------------------------------------------------------------------------------
# Frontend Application URL (used in email links and CORS validation)
PLATFORM_APP_URL=http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173

# Apex domain for tenant subdomains (e.g. {subdomain}.yourdomain.com)
# MMS_APP_DOMAIN=your-platform-domain.com

# ------------------------------------------------------------------------------
# 4. HTTP REQUEST LIMITS & PERFORMANCE
# ------------------------------------------------------------------------------
LOG_LEVEL=info
REQUEST_BODY_LIMIT_BYTES=1048576
REQUEST_TIMEOUT_MS=120000
MMS_SYNC_MAX_BODY_BYTES=52428800

# Security: Set TRUST_PROXY to trusted CIDRs/IPs in production (never 'true').
# TRUST_PROXY=127.0.0.1
COOKIE_SECURE=false

# ------------------------------------------------------------------------------
# 5. TRANSACTIONAL EMAIL SERVICES (Resend or SMTP)
# ------------------------------------------------------------------------------
# Provider Option A: Resend API (Recommended for production)
# PLATFORM_RESEND_API_KEY=re_123456789

# Provider Option B: SMTP (e.g. Gmail App Password)
# PLATFORM_SMTP_HOST=smtp.gmail.com
# PLATFORM_SMTP_PORT=587
# PLATFORM_SMTP_SECURE=false
# PLATFORM_SMTP_USER=user@example.com
# PLATFORM_SMTP_PASS=app-password
PLATFORM_EMAIL_FROM=noreply@your-verified-domain.com
PLATFORM_EMAIL_FROM_NAME=MMS Platform

# ------------------------------------------------------------------------------
# 6. STORAGE & ASSET PATHS
# ------------------------------------------------------------------------------
# Local directory for uploads (logos, avatars, attachments). Default: ./uploads
# MMS_UPLOADS_DIR=/var/www/mmsv2/apps/backend/uploads

# ------------------------------------------------------------------------------
# 7. PLATFORM SUPERUSER BOOTSTRAP (Disabled by default for security)
# ------------------------------------------------------------------------------
PLATFORM_ALLOW_ENV_BOOTSTRAP=false
# PLATFORM_ADMIN_EMAIL=admin@your-domain.com
# PLATFORM_ADMIN_PASSWORD=SuperSecretPass123!
# PLATFORM_ADMIN_NAME=Platform Admin
