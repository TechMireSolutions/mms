# Copy to apps/backend/.env for local dev (never commit .env).
# Production: set the same keys as GitHub repository secrets — deploy merges them via scripts/merge-backend-env.sh

JWT_SECRET=change-me
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mms

# --- Platform email (pick ONE provider) ---

# Option A (recommended): Resend — single API key + verified sender
# https://resend.com/api-keys
PLATFORM_RESEND_API_KEY=
PLATFORM_EMAIL_FROM=noreply@your-verified-domain.com
PLATFORM_EMAIL_FROM_NAME=MMS Platform
PLATFORM_APP_URL=https://your-apex-domain.com

# Option B: SMTP (e.g. Gmail app password)
# PLATFORM_SMTP_HOST=smtp.gmail.com
# PLATFORM_SMTP_PORT=587
# PLATFORM_SMTP_SECURE=false
# PLATFORM_SMTP_USER=
# PLATFORM_SMTP_PASS=
# PLATFORM_EMAIL_FROM=
# PLATFORM_EMAIL_FROM_NAME=MMS Platform
# PLATFORM_APP_URL=https://your-apex-domain.com

# --- Optional: seed first super-user without email OTP (disable after first deploy) ---
# PLATFORM_ALLOW_ENV_BOOTSTRAP=true
# PLATFORM_ADMIN_EMAIL=admin@yourdomain.com
# PLATFORM_ADMIN_PASSWORD=
# PLATFORM_ADMIN_NAME=Platform Admin

# Apex domain for tenant subdomain parsing (set per deployment)
# MMS_APP_DOMAIN=your-platform-domain.com

# Public platform URL (emails, links)
# PLATFORM_APP_URL=https://your-platform-domain.com

# Branding asset storage (logos uploaded during onboarding). Defaults to apps/backend/uploads
# MMS_UPLOADS_DIR=/var/www/mmsv2/apps/backend/uploads
