# MMS production vhost — Apache proxies all traffic to Fastify on :5002 (API + SPA) by default.
# Replace @@MMS_APP_DOMAIN@@ and @@BACKEND_PORT@@ before enabling.
# SSL paths: adjust for your certbot / hosting layout.

<VirtualHost *:80>
    ServerName @@MMS_APP_DOMAIN@@
    ServerAlias *.@@MMS_APP_DOMAIN@@
    RewriteEngine On
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</VirtualHost>

<VirtualHost *:443>
    ServerName @@MMS_APP_DOMAIN@@
    ServerAlias *.@@MMS_APP_DOMAIN@@

    SSLEngine on
    # Example certbot paths — update if your host uses different files:
    # SSLCertificateFile /etc/letsencrypt/live/@@MMS_APP_DOMAIN@@/fullchain.pem
    # SSLCertificateKeyFile /etc/letsencrypt/live/@@MMS_APP_DOMAIN@@/privkey.pem
    Include /etc/letsencrypt/options-ssl-apache.conf

    # Security headers (mms-security.mdc — terminate TLS here, not in Node)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    ProxyPreserveHost On
    RequestHeader unset X-Forwarded-Host
    RequestHeader set X-Forwarded-Proto "https"

    ProxyPass / http://127.0.0.1:@@BACKEND_PORT@@/
    ProxyPassReverse / http://127.0.0.1:@@BACKEND_PORT@@/

    ErrorLog ${APACHE_LOG_DIR}/mmsv2-error.log
    CustomLog ${APACHE_LOG_DIR}/mmsv2-access.log combined
</VirtualHost>
